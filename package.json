{
  "name": "cad-preview",
  "version": "0.1.2",
  "description": "Extract the embedded preview/thumbnail image from CAD and 3D files (SolidWorks, 3MF, FreeCAD, Inventor, …) — pure JS, cross-platform, no native CAD tools required.",
  "keywords": [
    "cad",
    "3d",
    "thumbnail",
    "preview",
    "solidworks",
    "sldprt",
    "inventor",
    "solidedge",
    "rhino",
    "3dm",
    "dwg",
    "dxf",
    "autocad",
    "blender",
    "sketchup",
    "3dsmax",
    "revit",
    "3mf",
    "freecad",
    "fusion360"
  ],
  "license": "MIT",
  "author": "Cameron Tacklind",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/cinderblock/cad-preview.git"
  },
  "bugs": {
    "url": "https://github.com/cinderblock/cad-preview/issues"
  },
  "homepage": "https://github.com/cinderblock/cad-preview#readme",
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "test": "bun test",
    "typecheck": "tsc --noEmit",
    "build": "tsup",
    "prepublishOnly": "bun run build"
  },
  "dependencies": {
    "cfb": "^1.2.2",
    "fflate": "^0.8.3",
    "fzstd": "^0.1.1"
  },
  "devDependencies": {
    "@types/bun": "^1.3.0",
    "tsup": "^8.5.1",
    "typescript": "^6.0.2"
  }
}
